# ── Application ────────────────────────────────────────────────────────────────
APP_NAME="Agentic AI Enterprise Assistant"
DEBUG=false
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_ai

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_GENERATE_A_REAL_FERNET_KEY

# ── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── OpenAI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# ── Google OAuth ─────────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Microsoft OAuth ───────────────────────────────────────────────────────────────
# Create at: https://portal.azure.com/ → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback

# ── Slack OAuth ───────────────────────────────────────────────────────────────────
# Create at: https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8000/api/auth/slack/callback
SLACK_SCOPES=channels:read,chat:write,im:read,im:write,users:read

# ── Jira ──────────────────────────────────────────────────────────────────────────
# JIRA_BASE_URL is your Atlassian instance, e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=https://yourcompany.atlassian.net

# ── Notion ────────────────────────────────────────────────────────────────────────
NOTION_API_VERSION=2022-06-28

# ── Rate limiting ─────────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
